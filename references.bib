	doi = {10.1017/bhj.2024.15},
	shorttitle = {Fossil Fuel Industry Divestment and the Energy Transition},
	abstract = {While divestments and decisions to exit commercial fossil fuel ventures are not new, the imperatives of the energy transition are catalysing such moves at a global industry-wide level, as oil companies position themselves for the future. The international normative framework for business and human rights provides clear guidance on how responsible divestment from fossil fuels should occur; however, in the absence of intergovernmental coordination and regulation, individual business divestment decisions create severe human rights risks. The case of Shell’s divestment from onshore Niger Delta oil production illustrates business and human rights issues relevant to the energy transition.},
	pages = {301--307},
